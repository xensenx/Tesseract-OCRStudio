{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static",
      "config": { "excludeFiles": "api/**" }
    }
  ],
  "routes": [
    {
      "src": "/api/maintenance",
      "dest": "/api/maintenance.js"
    },
    {
      "src": "/api/config",
      "dest": "/api/config.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "GEMMA_API_KEY_ONE": "@gemma_api_key_one",
    "GEMMA_API_KEY_TWO": "@gemma_api_key_two"
  }
}
